# Copy this file to scripts/stack.env and set real commands before boot install.

# Base directory where commands should run.
APP_DIR=/home/dan/Projects/SynthiaAiNode

# Backend process command.
# Example: BACKEND_CMD="PYTHONPATH=src /home/dan/Projects/SynthiaAiNode/.venv/bin/python -m ai_node.main --api-host 0.0.0.0 --api-port 9002"
BACKEND_CMD="PYTHONPATH=src /home/dan/Projects/SynthiaAiNode/.venv/bin/python -m ai_node.main --api-host 0.0.0.0 --api-port 9002"

# Frontend process command.
# Example: FRONTEND_CMD="cd frontend && npm run dev -- --host 0.0.0.0 --port 8081"
FRONTEND_CMD="cd frontend && npm run dev -- --host 0.0.0.0 --port 8081"
